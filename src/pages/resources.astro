---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Resources — Forge T Labs"
  description="Download the free Forge T Labs guide: Dynamics 365 for Construction."
  canonical="https://forgetlabs.com/resources"
  ogType="website"
  
>
<main id="top">
<section class="page-hero">
  <div class="hero-glow"></div>
  <div class="wrap">
    <div class="crumb"><a href="/">Home</a> &nbsp;/&nbsp; Resources</div>
    <h1>Free <em>resources</em>.</h1>
    <p class="lede">Practical guides for teams adopting the Microsoft Cloud. Tell us where to send
      it and the download is yours.</p>
  </div>
</section>

<section>
  <div class="wrap contact-grid">
    <div class="reveal">
      <span class="mono" style="color:var(--green);display:block;margin-bottom:14px">The guide</span>
      <h2 style="font-family:'Playfair Display';font-weight:700;font-size:2rem;margin-bottom:14px">
        Dynamics 365 for Construction</h2>
      <p style="color:var(--ink-dim);margin-bottom:16px">A practical guide for commercial
        contractors evaluating Microsoft Dynamics 365 &mdash; what it covers, where it fits, the
        construction workflows that matter, and how to sequence a rollout.</p>
      <div class="isv-feat">
        <div><span class="k">FOR</span><span class="v">Commercial general contractors and construction leadership.</span></div>
        <div><span class="k">COVERS</span><span class="v">Bid pipeline, project financials, RFIs, change orders, field operations.</span></div>
        <div><span class="k">FORMAT</span><span class="v">PDF guide &mdash; sent to your inbox, no sales call required.</span></div>
      </div>
      <p style="color:var(--ink-faint);font-size:.85rem;margin-top:22px;font-family:'IBM Plex Mono'">
        &#8627; Your details are used to send the guide and follow up once. We do not share them.</p>
    </div>

    <div class="form-card reveal">
      <form id="resourceForm" novalidate>
        <div style="position:absolute;left:-9999px" aria-hidden="true">
          <label>Website<input type="text" id="website" name="website" tabindex="-1" autocomplete="off" /></label>
        </div>
        <div class="field">
          <label for="name">Full name <span class="req">*</span></label>
          <input type="text" id="name" name="name" placeholder="Jane Doe" required />
          <div class="err">Please enter your name.</div>
        </div>
        <div class="field">
          <label for="email">Work email <span class="req">*</span></label>
          <input type="email" id="email" name="email" placeholder="jane@company.com" required />
          <div class="err">Please enter a valid email address.</div>
        </div>
        <div class="field">
          <label for="company">Company <span class="req">*</span></label>
          <input type="text" id="company" name="company" placeholder="Company name" required />
          <div class="err">Please enter your company.</div>
        </div>
        <div class="field">
          <label for="role">Your role <span style="color:var(--ink-faint)">(optional)</span></label>
          <input type="text" id="role" name="role" placeholder="e.g. Operations Director" />
        </div>
        <div class="form-foot">
          <button type="submit" class="btn btn-primary">Send me the guide &rarr;</button>
          <span class="note">Instant download. We follow up once, then leave you be.</span>
        </div>
      </form>
      <div class="form-success" id="formSuccess">
        <div class="ok"><svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="#3fc878" stroke-width="2.4">
          <path d="M5 13l4 4 10-11" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        <h3>Your guide is ready.</h3>
        <p id="successText">Thanks &mdash; click below to download. We have also emailed you a copy.</p>
        <div class="hero-actions" style="justify-content:center;margin-top:24px">
          <a class="btn btn-primary" id="downloadLink" href="Dynamics-365-for-Construction-Guide.pdf" download>Download the guide &rarr;</a>
        </div>
      </div>
    </div>
  </div>
</section>
</main>
</BaseLayout>
