---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Resources — Forge T Labs"
  description="Download the Dynamics 365 for Construction guide and other resources from Forge T Labs."
  canonical="https://forgetlabs.com/resources"
  active=""
>
<main>
  <section class="hero alt">
    <div class="container">
      <div class="hero-content reveal">
        <h1>Resources</h1>
        <p class="subtitle">Practical guides and tools to help you modernise your construction business.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">

      <div id="resourceFormWrap" class="card" style="padding:48px 40px;max-width:600px;margin:0 auto;">
        <h2 style="margin-bottom:8px;">Dynamics 365 for Construction</h2>
        <p style="margin-bottom:28px;color:var(--text-muted);">Fill in your details to download the free guide.</p>

        <form id="resourceForm" novalidate>
          <input type="text" name="website" id="website" style="display:none;" tabindex="-1" autocomplete="off">

          <div class="form-group">
            <label for="res-name">Full Name <span class="req">*</span></label>
            <input type="text" id="res-name" name="name" placeholder="Jane Smith" required>
          </div>
          <div class="form-group">
            <label for="res-email">Work Email <span class="req">*</span></label>
            <input type="email" id="res-email" name="email" placeholder="jane@company.com" required>
          </div>
          <div class="form-group">
            <label for="res-company">Company</label>
            <input type="text" id="res-company" name="company" placeholder="Acme Construction">
          </div>
          <div class="form-group">
            <label for="res-role">Your Role</label>
            <input type="text" id="res-role" name="role" placeholder="e.g. Project Manager">
          </div>

          <div class="form-foot">
            <button type="submit" class="btn btn-primary" id="resSubmitBtn">Get the Free Guide &rarr;</button>
            <p class="note" style="margin-top:12px;font-size:0.85rem;color:var(--text-muted);"></p>
          </div>
        </form>
      </div>

      <div id="formSuccess" class="card reveal" style="display:none;padding:48px 40px;max-width:600px;margin:0 auto;text-align:center;">
        <div style="font-size:3rem;margin-bottom:16px;">&#127881;</div>
        <h2 style="margin-bottom:12px;">You're all set!</h2>
        <p id="successText" style="margin-bottom:28px;color:var(--text-muted);">Thanks &mdash; we have also emailed you a copy.</p>
        <div class="hero-actions" style="justify-content:center;margin-top:24px;">
          <a class="btn btn-primary" id="downloadLink" href="/Dynamics-365-for-Construction-Guide.pdf" download>Download the guide &rarr;</a>
        </div>
      </div>

    </div>
  </section>
</main>

<script is:inline>
(function(){
  var form = document.getElementById('resourceForm');
  if(!form) return;
  var success = document.getElementById('formSuccess');
  var wrap    = document.getElementById('resourceFormWrap');

  // Basic email regex
  var emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  // Inline validation styling
  form.querySelectorAll('input').forEach(function(el){
    el.addEventListener('blur', function(){
      if(el.id==='website') return;
      var ok = true;
      if(el.required && !el.value.trim()) ok = false;
      if(el.id==='res-email' && el.value.trim() && !emailRe.test(el.value.trim())) ok = false;
      el.style.borderColor = ok ? '' : 'var(--danger, #e53e3e)';
    });
  });

  form.addEventListener('submit', function(e){
    e.preventDefault();

    // Honeypot check
    if(form.querySelector('#website') && form.querySelector('#website').value) return;

    // Validate
    var valid = true;
    form.querySelectorAll('input').forEach(function(el){
      if(el.id==='website') return;
      if(el.required && !el.value.trim()){ el.style.borderColor='var(--danger,#e53e3e)'; valid=false; }
      if(el.id==='res-email' && el.value.trim() && !emailRe.test(el.value.trim())){ el.style.borderColor='var(--danger,#e53e3e)'; valid=false; }
    });
    if(!valid) return;

    var btn = form.querySelector('button[type="submit"]');
    var lbl = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = 'Sending&hellip;';

    var payload = {
      name:    form.querySelector('#res-name').value.trim(),
      email:   form.querySelector('#res-email').value.trim(),
      company: form.querySelector('#res-company') ? form.querySelector('#res-company').value.trim() : '',
      role:    form.querySelector('#res-role') ? form.querySelector('#res-role').value.trim() : '',
      source:  'resources-guide'
    };

    fetch('/api/contact', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify(payload)
    })
    .then(function(r){ return r.json(); })
    .then(function(data){
      // Hide form, show success
      wrap.style.display = 'none';
      success.style.display = 'block';
      success.scrollIntoView({behavior:'smooth', block:'center'});
    })
    .catch(function(){
      btn.disabled = false;
      btn.innerHTML = lbl;
      var n = form.querySelector('.form-foot .note');
      if(n){ n.textContent = 'Something went wrong. Please try again, or email cssupport@forgetlabs.com.'; n.style.color='var(--danger,#e53e3e)'; }
    });
  });
})();
</script>
</BaseLayout>
