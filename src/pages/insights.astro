---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
);
---

<BaseLayout
  title="Insights — Forge T Labs"
  description="Articles and insights on Microsoft Dynamics 365, Azure, AI and the Microsoft Cloud for real estate and construction."
  canonical="https://forgetlabs.com/insights"
  ogType="website"
  active="Insights"
>

<main id="top">

<section class="page-hero">
  <div class="hero-glow"></div>
  <div class="wrap">
    <div class="crumb"><a href="/">Home</a> &nbsp;/&nbsp; Insights</div>
    <h1>Insights on the <em>Microsoft Cloud</em>.</h1>
    <p class="lede">Practical answers on Dynamics 365, Azure, AI and Modern Work &mdash; written
      for the teams making real decisions about their Microsoft platform.</p>
  </div>
</section>

<section>
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="mono">Latest</span>
      <h2>Articles &amp; <em>guidance</em>.</h2>
    </div>
    <div class="ind-grid">

      {posts.map((post) => (
        <a href={`/insights/${post.slug}`} class="ind reveal" style="display:block">
          <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="#3fc878" stroke-width="1.6">
            <path d="M3 21h18M6 21V8l6-4 6 4v13"/><path d="M10 21v-5h4v5" stroke-linejoin="round"/></svg></div>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
          {post.data.tags && post.data.tags.length > 0 && (
            <span class="tag">{post.data.tags[0]}</span>
          )}
        </a>
      ))}

    </div>
  </div>
</section>

<section style="padding-top:40px">
  <div class="wrap">
    <div class="cta-band reveal">
      <div class="glow"></div>
      <h2>Get the construction guide.</h2>
      <p>Our free guide goes deeper than the articles &mdash; the full picture of Dynamics 365
        for commercial contractors.</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/resources">Get the free guide &rarr;</a>
        <a class="btn btn-ghost" href="/contact">Talk to us</a>
      </div>
    </div>
  </div>
</section>

</main>
</BaseLayout>
